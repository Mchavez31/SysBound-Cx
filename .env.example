# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database — use SQLite locally, Postgres on Render
DATABASE_URL=sqlite:///./systemization.db

# Auth — generate a long random string for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changethis-generate-a-real-secret-key

# Anthropic API (Phase 3 — AI suggestions)
# ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
