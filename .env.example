# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database — use SQLite locally, Postgres on Render
DATABASE_URL=sqlite:///./systemization.db

# PDF comparison: parallel page workers per drawing (2–12, default 4). Lower on low-RAM machines.
# PDF_EXTRACT_WORKERS=4

# Auth — generate a long random string for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changethis-generate-a-real-secret-key

# Anthropic API (Phase 3 — AI suggestions)
# ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: frontend (Vite) — full API base if the UI is not served with a /api proxy.
# Leave unset for local dev so the Vite dev server can proxy /api to the backend.
# If set wrong, login and all API calls will time out or fail.
# Example: VITE_API_URL=https://your-api.example.com/api

# Frontend dev only (see frontend/.env.development): proxy target for /api (default http://127.0.0.1:8020)
# VITE_DEV_PROXY_API=http://127.0.0.1:8020
